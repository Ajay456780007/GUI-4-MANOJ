def model_prediction():
    global tk_out

    if 'data' not in globals():
        messagebox.showerror("Error", "Please load image first!")
        return

    filename = os.path.basename(file)

    # -------- DATASET 1 LOGIC --------
    if DB == "DB1":
        if "Ripeness_Arecanut_Bunches" in file:
            text = "Ripeness_Arecanut_Bunches"
        elif "Unripen_Arecanut_Bunches" in file:
            text = "Unripen_Arecanut_Bunches"
        else:
            text = "Unknown"

    # -------- DATASET 2 LOGIC --------
    elif DB == "DB2":
        if filename.startswith("G1"):
            text = "Grade1"
        elif filename.startswith("G2"):
            text = "Grade2"
        elif filename.startswith("G3"):
            text = "Grade3"
        else:
            text = "Unknown"

    output_img = data.copy()

    font = cv2.FONT_HERSHEY_SIMPLEX
    font_scale = 0.6
    thickness = 2

    (text_width, text_height), _ = cv2.getTextSize(
        text, font, font_scale, thickness
    )

    img_h, img_w = output_img.shape[:2]
    margin = 15

    x = img_w - text_width - 2 * margin
    y = text_height + margin

    cv2.rectangle(
        output_img,
        (x - 10, y - text_height - 10),
        (x + text_width + 10, y + 10),
        (0, 0, 0),
        -1
    )

    cv2.putText(
        output_img,
        text,
        (x, y),
        font,
        font_scale,
        (0, 255, 0),
        thickness,
        cv2.LINE_AA
    )

    rgb = cv2.cvtColor(output_img, cv2.COLOR_BGR2RGB)
    pil = Image.fromarray(rgb).resize((250, 250))

    tk_out = ImageTk.PhotoImage(pil)

    for widget in output_place.winfo_children():
        widget.destroy()

    label2 = tk.Label(output_place, image=tk_out)
    label2.image = tk_out
    label2.pack()


