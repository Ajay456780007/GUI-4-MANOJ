def Preprocessing(img):
    lab = cv2.cvtColor(img, cv2.COLOR_BGR2LAB)
    l, a, b = cv2.split(lab)

    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8, 8))
    cl = clahe.apply(l)

    limg = cv2.merge((cl, a, b))
    clahe_rgb = cv2.cvtColor(limg, cv2.COLOR_LAB2BGR)

    return clahe_rgb


